{
  "name": "enginescript/optimizations-ace-mc",
  "description": "Optimizations ACE MC - configurable optimizations for WordPress, WooCommerce, and WP Store Locator",
  "type": "wordpress-plugin",
  "license": "GPL-3.0-or-later",
  "authors": [
    {
      "name": "EngineScript",
      "email": "support@enginescript.com"
    }
  ],
  "minimum-stability": "stable",
  "require": {
    "php": ">=8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5 || ^12.0",
    "yoast/phpunit-polyfills": "^4.0",
    "squizlabs/php_codesniffer": "^3.13.5",
    "wp-coding-standards/wpcs": "^3.3",
    "phpcsstandards/phpcsextra": "^1.5",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.2",
    "friendsofphp/php-cs-fixer": "^3.95",
    "phpmd/phpmd": "^2.15",
    "vimeo/psalm": "^6.16",
    "php-stubs/wordpress-stubs": "^6.9",
    "szepeviktor/phpstan-wordpress": "^2.0",
    "phpstan/phpstan": "^2.1",
    "phpcompatibility/phpcompatibility-wp": "^2.1"
  },
  "scripts": {
    "phpcs": "phpcs --standard=phpcs.xml",
    "phpcs:fix": "phpcbf --standard=phpcs.xml",
    "phpmd": "phpmd . text phpmd.xml --exclude vendor,tests,stubs,assets,.private",
    "psalm": "psalm --config=psalm.xml --show-info=true",
    "phpstan": "phpstan analyze --memory-limit=1G",
    "test": "phpunit --configuration phpunit.xml --do-not-fail-on-empty-test-suite",
    "check-all": [
      "@phpcs",
      "@phpmd",
      "@psalm",
      "@phpstan",
      "@test"
    ]
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
